A while loop is used when you want to repeat something again and again until a condition becomes false.
“Keep doing this WHILE condition is true”

while (condition) {
    // code to run
}

Example 1:-
#include <iostream>
using namespace std;

int main() {
    int i = 1;

    while (i <= 5) {
        cout << i << endl;
        i++;
    }

    return 0;
}

Example 2:-
int num;

cout << "Enter number (0 to stop): ";
cin >> num;

while (num != 0) {
    cout << "You entered: " << num << endl;
    cin >> num;
}
