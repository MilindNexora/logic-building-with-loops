A while loop is used when you want to repeat something again and again until a condition becomes false.
“Keep doing this WHILE condition is true”

while (condition) {
    // code to run
}

Example 1:-
#include <iostream>
using namespace std;

int main() {
    int i = 1;

    while (i <= 5) {
        cout << i << endl;
        i++;
    }

    return 0;
}

Example 2:-
int num;

cout << "Enter number (0 to stop): ";
cin >> num;

while (num != 0) {
    cout << "You entered: " << num << endl;
    cin >> num;
}

Example 3:- C++ Code (Palindrome Check)

#include <iostream>
using namespace std;

int main() {
    int n, original, reverse = 0, digit;

    cout << "Enter a number: ";
    cin >> n;

    original = n;  // store original number

    // Reverse the number
    while (n > 0) {
        digit = n % 10;                  // get last digit
        reverse = reverse * 10 + digit;  // build reverse
        n = n / 10;                      // remove last digit
    }

    // Check palindrome
    if (original == reverse) {
        cout << "The given number is a palindrome." << endl;
    } else {
        cout << "The given number is not a palindrome." << endl;
    }

    return 0;
}

